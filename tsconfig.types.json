{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,

    "declaration": true,
    "emitDeclarationOnly": true,

    "outDir": "dist/types",
    "rootDir": "./src",

    "module": "ESNext",
    "moduleResolution": "bundler",

    "verbatimModuleSyntax": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "types", "public", "examples", "example"]
}